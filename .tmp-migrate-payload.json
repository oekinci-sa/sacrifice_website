ď»ż{"project_id":"xgrtwbvudkzvgavqskdt","name":"move_shareholder_sacrifice_2026_03_21","query":"-- rpc_move_shareholder_to_sacrifice: hissedarâ”€â–’ baâ”ĽĆ’ka kurbanlâ”€â–’â”€Ć’a taâ”ĽĆ’â”€â–’r (tek transaction).\n-- Kaynak kurbanlâ”€â–’kta empty_share +1, hedefte -1; toplam/kalan tutar yeni hisse bedeline gâ”śâ•˘re.\n-- Kurbanlâ”€â–’k satâ”€â–’rlarâ”€â–’ LEAST/GREATEST(sacrifice_id) sâ”€â–’rasâ”€â–’yla FOR UPDATE (deadlock â”śâ•˘nlemi).\n\nCREATE OR REPLACE FUNCTION public.rpc_move_shareholder_to_sacrifice(\n  p_actor text,\n  p_tenant_id uuid,\n  p_shareholder_id uuid,\n  p_target_sacrifice_id uuid\n)\nRETURNS public.shareholders\nLANGUAGE plpgsql\nSECURITY DEFINER\nSET search_path = public\nAS $f$\nDECLARE\n  v_sh public.shareholders;\n  v_src public.sacrifice_animals;\n  v_tgt public.sacrifice_animals;\n  v_id_low uuid;\n  v_id_high uuid;\n  v_new_total numeric;\n  v_new_remaining numeric;\n  v_paid numeric;\n  v_fee numeric;\nBEGIN\n  IF p_actor IS NULL OR btrim(p_actor) = '' THEN\n    RAISE EXCEPTION 'actor_required';\n  END IF;\n\n  PERFORM set_config('app.actor', p_actor, true);\n\n  SELECT * INTO v_sh\n  FROM public.shareholders sh\n  WHERE sh.shareholder_id = p_shareholder_id\n    AND sh.tenant_id = p_tenant_id\n  FOR UPDATE;\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION 'shareholder_not_found';\n  END IF;\n\n  IF v_sh.sacrifice_id = p_target_sacrifice_id THEN\n    RETURN v_sh;\n  END IF;\n\n  v_id_low := LEAST(v_sh.sacrifice_id, p_target_sacrifice_id);\n  v_id_high := GREATEST(v_sh.sacrifice_id, p_target_sacrifice_id);\n\n  PERFORM 1 FROM public.sacrifice_animals WHERE sacrifice_id = v_id_low FOR UPDATE;\n  IF NOT FOUND THEN\n    RAISE EXCEPTION 'sacrifice_row_missing';\n  END IF;\n\n  PERFORM 1 FROM public.sacrifice_animals WHERE sacrifice_id = v_id_high FOR UPDATE;\n  IF NOT FOUND THEN\n    RAISE EXCEPTION 'sacrifice_row_missing';\n  END IF;\n\n  SELECT * INTO v_src FROM public.sacrifice_animals WHERE sacrifice_id = v_sh.sacrifice_id;\n  IF NOT FOUND THEN\n    RAISE EXCEPTION 'source_sacrifice_not_found';\n  END IF;\n\n  SELECT * INTO v_tgt FROM public.sacrifice_animals WHERE sacrifice_id = p_target_sacrifice_id;\n  IF NOT FOUND THEN\n    RAISE EXCEPTION 'target_sacrifice_not_found';\n  END IF;\n\n  IF v_src.tenant_id <> p_tenant_id OR v_tgt.tenant_id <> p_tenant_id THEN\n    RAISE EXCEPTION 'tenant_mismatch';\n  END IF;\n\n  IF v_src.sacrifice_year IS DISTINCT FROM v_tgt.sacrifice_year THEN\n    RAISE EXCEPTION 'sacrifice_year_mismatch';\n  END IF;\n\n  IF v_tgt.empty_share < 1 THEN\n    RAISE EXCEPTION 'target_sacrifice_full';\n  END IF;\n\n  v_paid := COALESCE(v_sh.paid_amount, 0);\n  v_fee := COALESCE(v_sh.delivery_fee, 0);\n  v_new_total := v_tgt.share_price + v_fee;\n  v_new_remaining := GREATEST(v_new_total - v_paid, 0);\n\n  UPDATE public.sacrifice_animals sa\n  SET\n    empty_share = sa.empty_share + 1,\n    last_edited_by = p_actor,\n    last_edited_time = now()\n  WHERE sa.sacrifice_id = v_src.sacrifice_id;\n\n  UPDATE public.sacrifice_animals sa\n  SET\n    empty_share = sa.empty_share - 1,\n    last_edited_by = p_actor,\n    last_edited_time = now()\n  WHERE sa.sacrifice_id = v_tgt.sacrifice_id;\n\n  UPDATE public.shareholders sh\n  SET\n    sacrifice_id = v_tgt.sacrifice_id,\n    sacrifice_year = v_tgt.sacrifice_year,\n    total_amount = v_new_total,\n    remaining_payment = v_new_remaining,\n    last_edited_by = p_actor,\n    last_edited_time = now()\n  WHERE sh.shareholder_id = p_shareholder_id\n    AND sh.tenant_id = p_tenant_id\n  RETURNING * INTO v_sh;\n\n  RETURN v_sh;\nEND;\n$f$;\n\nREVOKE ALL ON FUNCTION public.rpc_move_shareholder_to_sacrifice(text, uuid, uuid, uuid) FROM PUBLIC;\nGRANT EXECUTE ON FUNCTION public.rpc_move_shareholder_to_sacrifice(text, uuid, uuid, uuid) TO service_role;\n\n\n-- shareholders Î“ĂĄĂ† change_logs; change_owner = app.actor (RPC) veya last_edited_by\n-- Aâ”śÂşâ”€â–’klamalar: admin panelinde okunabilir Tâ”śâ•ťrkâ”śÂşe â”śâ•˘zetler\n\nCREATE OR REPLACE FUNCTION public.log_shareholder_changes()\nRETURNS trigger\nLANGUAGE plpgsql\nAS $BODY$\nDECLARE\n  v_sacrifice_year INT2;\n  v_sacrifice_no INT2;\n  v_old_sac_no INT2;\n  v_new_sac_no INT2;\n  v_owner text;\nBEGIN\n  IF (TG_OP = 'INSERT' OR TG_OP = 'UPDATE') THEN\n    SELECT sa.sacrifice_year, sa.sacrifice_no\n    INTO v_sacrifice_year, v_sacrifice_no\n    FROM sacrifice_animals sa\n    WHERE sa.sacrifice_id = NEW.sacrifice_id;\n  ELSE\n    SELECT sa.sacrifice_year, sa.sacrifice_no\n    INTO v_sacrifice_year, v_sacrifice_no\n    FROM sacrifice_animals sa\n    WHERE sa.sacrifice_id = OLD.sacrifice_id;\n  END IF;\n\n  IF (TG_OP = 'INSERT') THEN\n    v_owner := COALESCE(\n      NULLIF(trim(COALESCE(current_setting('app.actor', true), '')), ''),\n      NEW.last_edited_by\n    );\n    INSERT INTO change_logs (table_name, row_id, change_type, description, change_owner, tenant_id, sacrifice_year)\n    VALUES (\n      'Hissedarlar',\n      CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'),\n      'Ekleme',\n      'Yeni hissedar kaydâ”€â–’ aâ”śÂşâ”€â–’ldâ”€â–’: â”¬Â˝' || NEW.shareholder_name || 'â”¬â•—. Baâ”€Ć’lâ”€â–’ kurbanlâ”€â–’k sâ”€â–’ra no: ' || COALESCE(v_sacrifice_no::text, 'Î“Ă‡Ă¶') || '.',\n      v_owner,\n      NEW.tenant_id,\n      v_sacrifice_year\n    );\n    RETURN NEW;\n\n  ELSIF (TG_OP = 'UPDATE') THEN\n    v_owner := COALESCE(\n      NULLIF(trim(COALESCE(current_setting('app.actor', true), '')), ''),\n      NEW.last_edited_by\n    );\n\n    IF NEW.shareholder_name IS DISTINCT FROM OLD.shareholder_name THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Hissedar Adâ”€â–’',\n        OLD.shareholder_name, NEW.shareholder_name, 'Gâ”śâ•ťncelleme',\n        'Hissedar gâ”śâ•˘râ”śâ•ťnen adâ”€â–’ deâ”€Ć’iâ”ĽĆ’ti: â”¬Â˝' || COALESCE(OLD.shareholder_name, 'Î“Ă‡Ă¶') || 'â”¬â•— Î“ĂĄĂ† â”¬Â˝' || COALESCE(NEW.shareholder_name, 'Î“Ă‡Ă¶') || 'â”¬â•—. Kurban sâ”€â–’ra: ' || COALESCE(v_sacrifice_no::text, 'Î“Ă‡Ă¶') || '.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.phone_number IS DISTINCT FROM OLD.phone_number THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Telefon Numarasâ”€â–’',\n        OLD.phone_number, NEW.phone_number, 'Gâ”śâ•ťncelleme',\n        'Birinci telefon gâ”śâ•ťncellendi. â”śĂ»nce: ' || COALESCE(OLD.phone_number, 'yok') || ', â”ĽĆ’imdi: ' || COALESCE(NEW.phone_number, 'yok') || '.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.second_phone_number IS DISTINCT FROM OLD.second_phone_number THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'â”€â–‘kinci Telefon',\n        OLD.second_phone_number, NEW.second_phone_number, 'Gâ”śâ•ťncelleme',\n        'â”€â–‘kinci / yedek telefon gâ”śâ•ťncellendi. â”śĂ»nce: ' || COALESCE(OLD.second_phone_number, 'yok') || ', â”ĽĆ’imdi: ' || COALESCE(NEW.second_phone_number, 'yok') || '.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.total_amount IS DISTINCT FROM OLD.total_amount THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Toplam Tutar',\n        CAST(OLD.total_amount AS TEXT), CAST(NEW.total_amount AS TEXT), 'Gâ”śâ•ťncelleme',\n        'Hissiye dâ”śâ•ťâ”ĽĆ’en toplam tutar (hisse + teslimat) deâ”€Ć’iâ”ĽĆ’ti: ' || COALESCE(OLD.total_amount::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘ Î“ĂĄĂ† ' || COALESCE(NEW.total_amount::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.paid_amount IS DISTINCT FROM OLD.paid_amount THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'â”śĂ»denen Tutar',\n        CAST(OLD.paid_amount AS TEXT), CAST(NEW.paid_amount AS TEXT), 'Gâ”śâ•ťncelleme',\n        'â”śĂ»denen tutar gâ”śâ•ťncellendi: ' || COALESCE(OLD.paid_amount::text, '0') || ' Î“Ă©â•‘ Î“ĂĄĂ† ' || COALESCE(NEW.paid_amount::text, '0') || ' Î“Ă©â•‘.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.remaining_payment IS DISTINCT FROM OLD.remaining_payment THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Kalan â”śĂ»deme',\n        CAST(OLD.remaining_payment AS TEXT), CAST(NEW.remaining_payment AS TEXT), 'Gâ”śâ•ťncelleme',\n        'Kalan â”śâ•˘deme tutarâ”€â–’: ' || COALESCE(OLD.remaining_payment::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘ Î“ĂĄĂ† ' || COALESCE(NEW.remaining_payment::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.delivery_fee IS DISTINCT FROM OLD.delivery_fee THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Teslimat â”śÂŁcreti',\n        CAST(OLD.delivery_fee AS TEXT), CAST(NEW.delivery_fee AS TEXT), 'Gâ”śâ•ťncelleme',\n        'Teslimat â”śâ•ťcreti: ' || COALESCE(OLD.delivery_fee::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘ Î“ĂĄĂ† ' || COALESCE(NEW.delivery_fee::text, 'Î“Ă‡Ă¶') || ' Î“Ă©â•‘.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.delivery_location IS DISTINCT FROM OLD.delivery_location THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Teslimat Noktasâ”€â–’',\n        OLD.delivery_location, NEW.delivery_location, 'Gâ”śâ•ťncelleme',\n        'Teslimat adresi veya noktasâ”€â–’ deâ”€Ć’iâ”ĽĆ’ti: â”¬Â˝' || COALESCE(OLD.delivery_location, 'belirtilmemiâ”ĽĆ’') || 'â”¬â•— Î“ĂĄĂ† â”¬Â˝' || COALESCE(NEW.delivery_location, 'belirtilmemiâ”ĽĆ’') || 'â”¬â•—.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.delivery_type IS DISTINCT FROM OLD.delivery_type THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Teslimat Tipi',\n        OLD.delivery_type, NEW.delivery_type, 'Gâ”śâ•ťncelleme',\n        'Teslimat â”ĽĆ’ekli gâ”śâ•ťncellendi (kesimhane / adrese / vb.): â”¬Â˝' || COALESCE(OLD.delivery_type, 'Î“Ă‡Ă¶') || 'â”¬â•— Î“ĂĄĂ† â”¬Â˝' || COALESCE(NEW.delivery_type, 'Î“Ă‡Ă¶') || 'â”¬â•—.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.sacrifice_consent IS DISTINCT FROM OLD.sacrifice_consent THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Vekalet',\n        CAST(OLD.sacrifice_consent AS TEXT), CAST(NEW.sacrifice_consent AS TEXT), 'Gâ”śâ•ťncelleme',\n        'Kurban vekaleti / onay kaydâ”€â–’ gâ”śâ•ťncellendi: ' || CASE WHEN OLD.sacrifice_consent THEN 'onaylâ”€â–’ydâ”€â–’' ELSE 'onaysâ”€â–’zdâ”€â–’' END || ' Î“ĂĄĂ† ' || CASE WHEN NEW.sacrifice_consent THEN 'onaylâ”€â–’' ELSE 'onaysâ”€â–’z' END || '.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.notes IS DISTINCT FROM OLD.notes THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Notlar',\n        OLD.notes, NEW.notes, 'Gâ”śâ•ťncelleme',\n        'Bu hissedar iâ”śÂşin not metni deâ”€Ć’iâ”ĽĆ’tirildi (detay eski/yeni sâ”śâ•ťtunlarda).',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.email IS DISTINCT FROM OLD.email THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'E-posta',\n        OLD.email, NEW.email, 'Gâ”śâ•ťncelleme',\n        'Hissedar e-posta adresi gâ”śâ•ťncellendi: ' || COALESCE(OLD.email, 'yok') || ' Î“ĂĄĂ† ' || COALESCE(NEW.email, 'yok') || '.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.security_code IS DISTINCT FROM OLD.security_code THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Gâ”śâ•ťvenlik Kodu',\n        OLD.security_code, NEW.security_code, 'Gâ”śâ•ťncelleme',\n        'Hisse sorgulamada kullanâ”€â–’lan 6 haneli gâ”śâ•ťvenlik kodu yenilendi (eski ve yeni deâ”€Ć’er kayâ”€â–’tta).',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.contacted_at IS DISTINCT FROM OLD.contacted_at THEN\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Gâ”śâ•˘râ”śâ•ťâ”ĽĆ’â”śâ•ťldâ”śâ•ť',\n        CAST(OLD.contacted_at AS TEXT), CAST(NEW.contacted_at AS TEXT), 'Gâ”śâ•ťncelleme',\n        'â”¬Â˝Gâ”śâ•˘râ”śâ•ťâ”ĽĆ’â”śâ•ťldâ”śâ•ťâ”¬â•— iâ”ĽĆ’areti veya gâ”śâ•˘râ”śâ•ťâ”ĽĆ’me tarihi gâ”śâ•ťncellendi; arama takibinde kullanâ”€â–’lâ”€â–’r.',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    IF NEW.sacrifice_id IS DISTINCT FROM OLD.sacrifice_id THEN\n      SELECT sa.sacrifice_no INTO v_old_sac_no FROM sacrifice_animals sa WHERE sa.sacrifice_id = OLD.sacrifice_id;\n      SELECT sa.sacrifice_no INTO v_new_sac_no FROM sacrifice_animals sa WHERE sa.sacrifice_id = NEW.sacrifice_id;\n      INSERT INTO change_logs (table_name, row_id, column_name, old_value, new_value, change_type, description, change_owner, tenant_id, sacrifice_year)\n      VALUES (\n        'Hissedarlar', CONCAT(NEW.shareholder_name, ' (', NEW.sacrifice_id, ')'), 'Baâ”€Ć’lâ”€â–’ Kurbanlâ”€â–’k',\n        COALESCE(v_old_sac_no::text, 'Î“Ă‡Ă¶'), COALESCE(v_new_sac_no::text, 'Î“Ă‡Ă¶'), 'Gâ”śâ•ťncelleme',\n        'Hissedar baâ”ĽĆ’ka kurbanlâ”€â–’â”€Ć’a taâ”ĽĆ’â”€â–’ndâ”€â–’: kurban sâ”€â–’ra no ' || COALESCE(v_old_sac_no::text, 'Î“Ă‡Ă¶') || ' Î“ĂĄĂ† ' || COALESCE(v_new_sac_no::text, 'Î“Ă‡Ă¶') || ' (boâ”ĽĆ’ hisse ve tutarlar gâ”śâ•ťncellendi).',\n        v_owner, NEW.tenant_id, v_sacrifice_year\n      );\n    END IF;\n\n    RETURN NEW;\n\n  ELSIF (TG_OP = 'DELETE') THEN\n    v_owner := COALESCE(\n      NULLIF(trim(COALESCE(current_setting('app.actor', true), '')), ''),\n      OLD.last_edited_by\n    );\n    INSERT INTO change_logs (table_name, row_id, change_type, description, change_owner, tenant_id, sacrifice_year)\n    VALUES (\n      'Hissedarlar',\n      CONCAT(OLD.shareholder_name, ' (', OLD.sacrifice_id, ')'),\n      'Silme',\n      'Hissedar kaydâ”€â–’ silindi veya kurbanlâ”€â–’kla birlikte kaldâ”€â–’râ”€â–’ldâ”€â–’: â”¬Â˝' || OLD.shareholder_name || 'â”¬â•—. Kurban sâ”€â–’ra no: ' || COALESCE(v_sacrifice_no::text, 'Î“Ă‡Ă¶') || '.',\n      v_owner,\n      OLD.tenant_id,\n      v_sacrifice_year\n    );\n    RETURN OLD;\n  END IF;\n\n  RETURN NULL;\nEND;\n$BODY$;\n\nDROP TRIGGER IF EXISTS trigger_shareholder_changes ON public.shareholders;\n\nCREATE TRIGGER trigger_shareholder_changes\n  AFTER INSERT OR UPDATE OR DELETE ON public.shareholders\n  FOR EACH ROW\n  EXECUTE FUNCTION log_shareholder_changes();\n"}
